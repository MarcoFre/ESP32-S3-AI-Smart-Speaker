# --- I2C per codec (ES8311/ES7210) ---
i2c:
  id: bus_i2c
  sda: ${i2c_sda}
  scl: ${i2c_scl}
  scan: true
  frequency: 100kHz

# --- I2S bus ---
i2s_audio:
  - id: bus_i2s
    i2s_mclk_pin: ${i2s_mclk}
    i2s_bclk_pin: ${i2s_bclk}
    i2s_lrclk_pin: ${i2s_lrclk}

# Expander della board (EXIO0..EXIO15)
tca9555:
  - id: exio
    address: 0x20

font:
  - file: "gfonts://Roboto"
    id: font_header
    size: 10
  - file: "gfonts://Roboto"
    id: font_timer_big
    size: 28

display:
  - platform: ssd1306_i2c
    id: oled
    model: "SSD1306 128x64"
    address: 0x3C
    update_interval: 200ms
    lambda: |-
      const uint32_t now = millis();
      const int phase = id(voice_assistant_phase);

      // Sempre pulisci lo schermo
      it.fill(COLOR_OFF);

      // ===== TIMER: scegli il primo attivo (o il più vicino se in pausa) =====
      bool has_timer = false;
      bool is_active_timer = false;
      uint32_t best_left = 0;
      uint32_t best_total = 0;

      const auto &timers = id(va).get_timers();
      if (!timers.empty()) {
        bool found = false;

        // 1) prima: timer attivi
        for (const auto &t : timers) {
          if (t.is_active) {
            if (!found || t.seconds_left < best_left) {
              best_left = t.seconds_left;
              best_total = t.total_seconds;
              found = true;
              is_active_timer = true;
            }
          }
        }

        // 2) se nessun attivo: prendi quello con meno secondi rimasti (paused)
        if (!found) {
          for (const auto &t : timers) {
            if (!found || t.seconds_left < best_left) {
              best_left = t.seconds_left;
              best_total = t.total_seconds;
              found = true;
              is_active_timer = false;
            }
          }
        }

        has_timer = found;
      }

      // ===== MODALITÀ TIMER (NO OCCHIETTI) =====
      if (has_timer) {
        uint32_t s = best_left;
        uint32_t hh = s / 3600U;
        uint32_t mm = (s % 3600U) / 60U;
        uint32_t ss = s % 60U;

        char buf[16];
        if (hh > 0) {
          // HH:MM (più leggibile sul display piccolo)
          snprintf(buf, sizeof(buf), "%02lu:%02lu", (unsigned long)hh, (unsigned long)mm);
        } else {
          // MM:SS
          snprintf(buf, sizeof(buf), "%02lu:%02lu", (unsigned long)mm, (unsigned long)ss);
        }

        // Se in pausa, scrivilo sopra piccolo
        if (!is_active_timer) {
          it.print(64, 0, id(font_header), TextAlign::TOP_CENTER, "PAUSA");
        }

        // Timer gigante centrato (usa quasi tutto lo schermo)
        it.printf(64, 26, id(font_timer_big), TextAlign::CENTER, "%s", buf);

        // Barra progresso in basso
        uint32_t tot = (best_total == 0) ? 1 : best_total;
        int w = (int) (128.0f * ((float)best_left / (float)tot));
        if (w < 0) w = 0;
        if (w > 128) w = 128;

        it.rectangle(0, 56, 128, 8);
        if (w > 2) it.filled_rectangle(1, 57, w - 2, 6);

        return;  // IMPORTANTISSIMO: niente faccina/occhi
      }

      // ===== QUI SOTTO: UI "normale" con occhietti Mochi-style =====

      // --- mini RNG deterministico (sempre disponibile) ---
      static uint32_t rng = 0xA5A5A5A5;
      auto rnd_u32 = [&]() -> uint32_t {
        rng = rng * 1664525UL + 1013904223UL;  // LCG
        return rng;
      };
      auto rnd_range = [&](int a, int b) -> int {  // inclusivo
        uint32_t r = rnd_u32();
        int span = (b - a + 1);
        return a + (int)(r % (uint32_t)span);
      };

      // --- easing ---
      auto smoothstep = [](float x) -> float {
        if (x < 0.0f) x = 0.0f;
        if (x > 1.0f) x = 1.0f;
        return x * x * (3.0f - 2.0f * x);
      };

      // --- disegno occhio Mochi: occhio pieno + pupilla "bucata" + highlight ---
      auto draw_eye_mochi = [&](int x, int y, int w, int h, float gaze_x, float gaze_y, float blink_amt) {
        // blink_amt: 0=open, 1=closed
        int openH = (int)(h * (1.0f - blink_amt));
        if (openH < 2) openH = 2;
        int yy = y + (h - openH) / 2;

        int r = openH / 2; if (r < 1) r = 1;
        int body_w = w - (r * 2); if (body_w < 1) body_w = 1;

        // corpo occhio
        it.filled_rectangle(x + r, yy, body_w, openH);
        it.filled_circle(x + r, yy + r, r);
        it.filled_circle(x + w - r - 1, yy + r, r);

        // pupilla solo se abbastanza aperto
        if (blink_amt < 0.85f) {
          int px = x + w/2 + (int)(gaze_x * (w * 0.18f));
          int py = yy + openH/2 + (int)(gaze_y * (openH * 0.20f));
          int pr = 3;

          it.filled_circle(px, py, pr, COLOR_OFF);     // pupilla (buca)
          it.filled_circle(px - 1, py - 1, 1, COLOR_ON); // highlight
        } else {
          // quasi chiuso: linea sottile
          it.line(x + 4, y + h/2, x + w - 5, y + h/2);
        }
      };

      auto draw_mouth = [&](int x, int y, int w, int h) {
        int r = h / 2;
        if (r < 1) r = 1;
        int body_w = w - (r * 2);
        if (body_w < 1) body_w = 1;

        it.filled_rectangle(x + r, y, body_w, h);
        it.filled_circle(x + r, y + r, r);
        it.filled_circle(x + w - r - 1, y + r, r);
      };

      // Titolo in alto
      const char* title = "PRONTA";
      if (phase == ${voice_assist_listening_phase_id})      title = "ASCOLTO";
      else if (phase == ${voice_assist_thinking_phase_id})  title = "PENSO";
      else if (phase == ${voice_assist_replying_phase_id})  title = "PARLO";
      else if (phase == ${voice_assist_muted_phase_id})     title = "MUTO";
      else if (phase == ${voice_assist_error_phase_id})     title = "ERRORE";
      else if (phase == ${no_connected})                    title = "OFFLINE";

      it.print(64, 2, id(font_header), TextAlign::TOP_CENTER, title);
      it.line(0, 15, 127, 15);

      // --- animazione Mochi: micro-saccadi + blink fluido ---
      static float gx = 0.0f, gy = 0.0f;       // gaze attuale [-1..1]
      static float gx_t = 0.0f, gy_t = 0.0f;   // gaze target
      static uint32_t next_saccade = 0;

      static float blink = 0.0f;               // 0 open, 1 closed
      static bool blinking = false;
      static uint32_t blink_start = 0;
      static uint32_t next_blink = 0;

      // aggiorna target gaze ogni tanto (solo in IDLE per "vita", negli altri stati lo fisso)
      if (phase == ${voice_assist_idle_phase_id}) {
        if (next_saccade == 0) next_saccade = now + 600;
        if (now >= next_saccade) {
          gx_t = rnd_range(-10, 10) / 10.0f;
          gy_t = rnd_range(-7,  7) / 10.0f;
          next_saccade = now + (uint32_t)rnd_range(600, 1800);
        }
      } else {
        gx_t = 0.0f;
        gy_t = 0.0f;
      }

      // lerp morbido verso target
      gx += (gx_t - gx) * 0.14f;
      gy += (gy_t - gy) * 0.14f;

      // blink fluido sempre (ma puoi limitarlo all’IDLE se vuoi)
      if (next_blink == 0) next_blink = now + 1800;
      if (!blinking && now >= next_blink) {
        blinking = true;
        blink_start = now;
      }
      if (blinking) {
        uint32_t dt = now - blink_start;
        if (dt <= 70) {
          blink = smoothstep(dt / 70.0f);
        } else if (dt <= 180) {
          blink = 1.0f - smoothstep((dt - 70) / 110.0f);
        } else {
          blink = 0.0f;
          blinking = false;
          next_blink = now + (uint32_t)rnd_range(1800, 4200);
        }
      }

      // coordinate occhi
      const int eyeW = 28;
      const int eyeH = 18;
      const int eyeY = 27;
      const int leftX  = 20;
      const int rightX = 80;

      // IDLE: occhi Mochi + sorriso
      if (phase == ${voice_assist_idle_phase_id}) {
        draw_eye_mochi(leftX,  eyeY, eyeW, eyeH, gx, gy, blink);
        draw_eye_mochi(rightX, eyeY, eyeW, eyeH, gx, gy, blink);
        it.line(54, 50, 72, 50);
      }

      // ASCOLTO
      else if (phase == ${voice_assist_listening_phase_id}) {
        draw_eye_mochi(leftX,  eyeY, eyeW, eyeH, 0.0f, 0.0f, blink * 0.6f);
        draw_eye_mochi(rightX, eyeY, eyeW, eyeH, 0.0f, 0.0f, blink * 0.6f);
        it.line(20, 24, 38, 22);
        it.line(90, 22, 108, 24);
        it.line(58, 50, 68, 50);
      }

      // PENSO
      else if (phase == ${voice_assist_thinking_phase_id}) {
        draw_eye_mochi(leftX,  eyeY+7, 24, 10, 0.0f, 0.0f, blink * 0.8f);
        draw_eye_mochi(rightX, eyeY+7, 24, 10, 0.0f, 0.0f, blink * 0.8f);

        int dots = ((now / 450) % 3) + 1;
        if (dots >= 1) it.filled_circle(54, 50, 2);
        if (dots >= 2) it.filled_circle(64, 50, 2);
        if (dots >= 3) it.filled_circle(74, 50, 2);
      }

      // PARLO
      else if (phase == ${voice_assist_replying_phase_id}) {
        draw_eye_mochi(leftX+4,  eyeY+3, 24, 14, 0.0f, 0.0f, blink * 0.6f);
        draw_eye_mochi(rightX+2, eyeY+3, 24, 14, 0.0f, 0.0f, blink * 0.6f);

        int mouth_h = 4;
        uint32_t talk = (now / 160) % 4;
        if (talk == 1) mouth_h = 8;
        else if (talk == 2) mouth_h = 12;
        else if (talk == 3) mouth_h = 7;

        draw_mouth(46, 46, 36, mouth_h);
      }

      // MUTO
      else if (phase == ${voice_assist_muted_phase_id}) {
        draw_eye_mochi(leftX+4,  eyeY+6, 22, 10, 0.0f, 0.0f, 0.90f);
        draw_eye_mochi(rightX+2, eyeY+6, 22, 10, 0.0f, 0.0f, 0.90f);
        it.line(48, 50, 80, 50);
        it.line(46, 54, 82, 44);
      }

      // ERRORE / fallback
      else {
        draw_eye_mochi(leftX+6,  eyeY+10, 18, 6, 0.0f, 0.0f, 0.95f);
        draw_eye_mochi(rightX+6, eyeY+10, 18, 6, 0.0f, 0.0f, 0.95f);
        it.line(50, 52, 78, 52);
      }
binary_sensor:
  - platform: gpio
    id: key_vol_up
    name: "Tasto Volume +"
    icon: "mdi:volume-plus"
    entity_category: diagnostic
    pin:
      tca9555: exio
      number: 11
      mode: INPUT
      inverted: true
    filters:
      - delayed_on: 20ms
    on_press:
      - if:
          condition:
            lambda: return id(audio_muted);
          then:
            - audio_dac.mute_off:
                id: dac
            - lambda: id(audio_muted) = false;
            - script.execute: set_idle_or_mute_phase
            - script.execute: start_wake_word
            - script.execute: control_leds
      - media_player.volume_up:
          id: ${mediaplayer_name}
      - logger.log:
          level: INFO
          format: "==== VOLUME +"

  - platform: gpio
    id: key_mute
    name: "Tasto Mute"
    icon: "mdi:volume-mute"
    entity_category: diagnostic
    pin:
      tca9555: exio
      number: 10
      mode: INPUT
      inverted: true
    filters:
      - delayed_on: 20ms
    on_press:
      - if:
          condition:
            lambda: return id(audio_muted);
          then:
            - script.execute: play_mute_on_sound
            - audio_dac.mute_off:
                id: dac
            - lambda: id(audio_muted) = false;
            - script.execute: set_idle_or_mute_phase
            - script.execute: start_wake_word
            - script.execute: control_leds
          else:
            - script.execute: stop_wake_word
            - script.execute: play_mute_off_sound
            - audio_dac.mute_on:
                id: dac
            - lambda: id(audio_muted) = true;
            - lambda: id(voice_assistant_phase_prev) = id(voice_assistant_phase);
            - script.execute: set_idle_or_mute_phase
            - script.execute: control_leds

  - platform: gpio
    id: key_vol_down
    name: "Tasto Volume -"
    icon: "mdi:volume-minus"
    entity_category: diagnostic
    pin:
      tca9555: exio
      number: 9
      mode: INPUT
      inverted: true
    filters:
      - delayed_on: 20ms
    on_press:
      - if:
          condition:
            lambda: return id(audio_muted);
          then:
            - audio_dac.mute_off:
                id: dac
            - lambda: id(audio_muted) = false;
            - script.execute: set_idle_or_mute_phase
            - script.execute: start_wake_word
            - script.execute: control_leds
      - media_player.volume_down:
          id: ${mediaplayer_name}
      - logger.log:
