globals:
  - id: continuous_listening_mode
    type: bool
    restore_value: yes
    initial_value: "true"
    
  - id: auto_stop_count
    type: uint32_t
    restore_value: false
    initial_value: "0"

  - id: init_in_progress
    type: uint32_t
    restore_value: false
    initial_value: "0"

  - id: wifi_ok
    type: bool
    restore_value: false
    initial_value: "false"

  - id: api_ok
    type: bool
    restore_value: false
    initial_value: "false"

  - id: wifi_flash_until
    type: uint32_t
    restore_value: false
    initial_value: "0"

  - id: api_flash_until
    type: uint32_t
    restore_value: false
    initial_value: "0"

  - id: va_running
    type: uint32_t
    restore_value: false
    initial_value: "0"

  - id: mp_running
    type: uint32_t
    restore_value: false
    initial_value: "0"

  - id: mww_running
    type: uint32_t
    restore_value: false
    initial_value: "0"

  - id: voice_assistant_phase
    type: int
    restore_value: false
    initial_value: ${no_connected}

  - id: voice_assistant_phase_prev
    type: int
    restore_value: false
    initial_value: ${no_connected}

  - id: ts_va_listening_ms
    type: uint32_t
    restore_value: false
    initial_value: '0'

  - id: ts_va_vad_end_ms
    type: uint32_t
    restore_value: false
    initial_value: '0'

  - id: ts_va_stt_end_ms
    type: uint32_t
    restore_value: false
    initial_value: '0'

  - id: ts_va_tts_start_ms
    type: uint32_t
    restore_value: false
    initial_value: '0'

  - id: ts_va_reply_done_ms
    type: uint32_t
    restore_value: false
    initial_value: '0'

  - id: ts_va_end_ms
    type: uint32_t
    restore_value: false
    initial_value: '0'

  - id: question
    type: std::string
    restore_value: no
    initial_value: '""'

  - id: answer
    type: std::string
    restore_value: no
    initial_value: '""'

  - id: audio_muted
    type: bool
    restore_value: no
    initial_value: "false"

  - id: fg_r
    type: int
    initial_value: "0"

  - id: fg_g
    type: int
    initial_value: "0"

  - id: fg_b
    type: int
    initial_value: "0"

  - id: bg_r
    type: int
    initial_value: "0"

  - id: bg_g
    type: int
    initial_value: "0"

  - id: bg_b
    type: int
    initial_value: "0"

script:
  - id: start_voice_assistant
    then:
      - if:
          condition:
            not:
              voice_assistant.is_running:
          then:
            - if:
                condition:
                  lambda: return id(continuous_listening_mode);
                then:
                  - voice_assistant.start_continuous:
                  - logger.log:
                      level: INFO
                      format: "==== Script: Voice Assistant Start (CONTINUOUS) ===="
                  - wait_until:
                      condition:
                        not:
                          - voice_assistant.is_running
                      timeout: 30s
                  - if:
                      condition:
                        not:
                          - voice_assistant.is_running
                      then:
                        - logger.log:
                            level: INFO
                            format: "Script: Voice Assistant Start Failed after 30s (CONTINUOUS)."
                      else:
                        - logger.log:
                            level: INFO
                            format: "Script: Voice Assistant Started (CONTINUOUS)."
                else:
                  - voice_assistant.start:
                  - logger.log:
                      level: INFO
                      format: "==== Script: Voice Assistant Start (SINGLE) ===="
                  - wait_until:
                      condition:
                        not:
                          - voice_assistant.is_running
                      timeout: 30s
                  - if:
                      condition:
                        not:
                          - voice_assistant.is_running
                      then:
                        - logger.log:
                            level: INFO
                            format: "Script: Voice Assistant Start Failed after 30s (SINGLE)."
                      else:
                        - logger.log:
                            level: INFO
                            format: "Script: Voice Assistant Started (SINGLE)."
            - lambda: id(voice_assistant_phase) = ${voice_assist_listening_phase_id};
            - lambda: id(va_running) = true;
            - script.execute: control_leds

  - id: play_wake_sound
    then:
      - logger.log:
          level: INFO
          format: "==== BEEP -> WAKE WORD"
      - if:
          condition:
            not:
              - media_player.is_announcing: ${mediaplayer_name}
          then:
            - media_player.speaker.play_on_device_media_file:
                media_file: wake_word_triggered_sound
                announcement: true

  - id: play_mute_on_sound
    then:
      - logger.log:
          level: INFO
          format: "==== BEEP -> MUTE ON"
      - script.execute: stop_wake_word
      - if:
          condition:
            lambda: return id(voice_assistant_phase) != ${voice_assist_idle_phase_id};
          then:
            - voice_assistant.stop:
      - if:
          condition:
            - media_player.is_announcing: ${mediaplayer_name}
          then:
            - media_player.stop: ${mediaplayer_name}

      - media_player.speaker.play_on_device_media_file:
          media_file: mute_switch_on_sound
          announcement: true
      - wait_until:
          condition:
            - media_player.is_announcing: ${mediaplayer_name}
          timeout: 500ms
      - wait_until:
          condition:
            not:
              - media_player.is_announcing: ${mediaplayer_name}
          timeout: 2s

  - id: play_mute_off_sound
    then:
      - logger.log:
          level: INFO
          format: "==== BEEP -> MUTE OFF"
      - if:
          condition:
            not:
              - media_player.is_announcing: ${mediaplayer_name}
          then:
            - media_player.speaker.play_on_device_media_file:
                media_file: mute_switch_off_sound
                announcement: true

  - id: play_timer_finished_sound
    then:
      - if:
          condition:
            not:
              - media_player.is_announcing: ${mediaplayer_name}
          then:
            - media_player.speaker.play_on_device_media_file:
                media_file: timer_finished_sound
                announcement: true

  - id: start_wake_word
    then:
      - if:
          condition:
            lambda: return !id(audio_muted);
          then:
            - if:
                condition:
                  not:
                    - lambda: return id(va_running);
                then:
                  - if:
                      condition:
                        not:
                          - micro_wake_word.is_running
                      then:
                        - micro_wake_word.start:
                        - delay: 50ms
                        - logger.log:
                            level: INFO
                            format: "==== WakeWord: Start"
                        - wait_until:
                            condition:
                              not:
                                - micro_wake_word.is_running
                            timeout: 30s
                        - if:
                            condition:
                              not:
                                - micro_wake_word.is_running
                            then:
                              - logger.log:
                                  level: INFO
                                  format: "==== WakeWord: Start Failed after 30s."
                            else:
                              - logger.log:
                                  level: INFO
                                  format: "==== WakeWord: Started !"
                      else:
                        - if:
                            condition:
                              not:
                                - micro_wake_word.is_running
                            then:
                              - micro_wake_word.start:
                              - delay: 50ms
                              - logger.log:
                                  level: INFO
                                  format: "==== WakeWord: Start"
                        - wait_until:
                            condition:
                              not:
                                - micro_wake_word.is_running
                            timeout: 30s
                        - if:
                            condition:
                              not:
                                - micro_wake_word.is_running
                            then:
                              - logger.log:
                                  level: INFO
                                  format: "==== WakeWord: Start Failed after 30s."
                            else:
                              - logger.log:
                                  level: INFO
                                  format: "==== WakeWord: Started !"

  - id: stop_wake_word
    then:
      - if:
          condition:
            - micro_wake_word.is_running
          then:
            - micro_wake_word.stop:
            - delay: 50ms
            - logger.log:
                level: INFO
                format: "==== WakeWord: Stop"

  - id: set_idle_or_mute_phase
    then:
      - if:
          condition:
            lambda: return id(audio_muted);
          then:
            - lambda: id(voice_assistant_phase) = ${voice_assist_muted_phase_id};
          else:
            - lambda: id(voice_assistant_phase) = ${voice_assist_idle_phase_id};

  - id: control_leds
    mode: restart
    then:
      - logger.log:
          level: INFO
          format: "==== CONTROL LED: %d"
          args: ['id(voice_assistant_phase)']

      - if:
          condition:
            lambda: |-
              return id(voice_assistant_phase) == ${voice_assist_idle_phase_id} ||
                     id(voice_assistant_phase) == ${voice_assist_listening_phase_id} ||
                     id(voice_assistant_phase) == ${voice_assist_thinking_phase_id} ||
                     id(voice_assistant_phase) == ${voice_assist_replying_phase_id} ||
                     id(voice_assistant_phase) == ${mediaplayer_play};
          then:
            - lambda: id(voice_assistant_phase_prev) = id(voice_assistant_phase);

      - if:
          condition:
            lambda: return id(voice_assistant_phase) == ${no_connected};
          then:
            - light.turn_on:
                id: led_ring
                brightness: 75%
                effect: "Error Blink"
            - lambda: id(va_running) = false;
            - lambda: id(mp_running) = false;
            - lambda: id(mww_running) = false;
      - if:
          condition:
            lambda: return id(voice_assistant_phase) == ${connected_wireless};
          then:
            - light.turn_on:
                id: led_ring
                brightness: 75%
                effect: "WiFi Blink"

      - if:
          condition:
            lambda: return id(voice_assistant_phase) == ${connected_wireless_api};
          then:
            - light.turn_on:
                id: led_ring
                brightness: 75%
                effect: "API Blink"

      - if:
          condition:
            lambda: return id(voice_assistant_phase) == ${voice_assist_not_ready_phase_id};
          then:
            - light.turn_on:
                id: led_ring
                brightness: 60%
                effect: "Error Blink"
            - lambda: id(va_running) = false;
            - lambda: id(mp_running) = false;
            - lambda: id(mww_running) = false;

      - if:
          condition:
            lambda: return id(voice_assistant_phase) == ${voice_assist_error_phase_id};
          then:
            - light.turn_on:
                id: led_ring
                brightness: 75%
                effect: "Error Blink"
            - lambda: id(va_running) = false;

      - if:
          condition:
            lambda: return id(voice_assistant_phase) == ${voice_assist_idle_phase_id};
          then:
            - script.execute: led_waiting_wake
            - lambda: id(va_running) = false;
            - lambda: id(mp_running) = false;
            - lambda: id(mww_running) = true;

      - if:
          condition:
            lambda: return id(voice_assistant_phase) == ${voice_assist_listening_phase_id};
          then:
            - script.execute: led_listening
            - lambda: id(va_running) = true;
            - lambda: id(mp_running) = false;
            - lambda: id(mww_running) = false;

      - if:
          condition:
            lambda: return id(voice_assistant_phase) == ${voice_assist_thinking_phase_id};
          then:
            - script.execute: led_thinking
            - lambda: id(va_running) = true;
            - lambda: id(mp_running) = false;
            - lambda: id(mww_running) = false;

      - if:
          condition:
            lambda: return id(voice_assistant_phase) == ${voice_assist_replying_phase_id};
          then:
            - light.turn_on:
                id: led_ring
                brightness: 75%
                effect: "Play"
            - lambda: id(va_running) = true;
            - lambda: id(mp_running) = false;
            - lambda: id(mww_running) = false;

      - if:
          condition:
            lambda: return id(voice_assistant_phase) == ${mediaplayer_play};
          then:
            - light.turn_on:
                id: led_ring
                brightness: 75%
                effect: "Slow Pulse"
            - lambda: id(va_running) = false;
            - lambda: id(mp_running) = true;
            - lambda: id(mww_running) = false;

      - if:
          condition:
            lambda: return id(voice_assistant_phase) == ${voice_assist_muted_phase_id};
          then:
            - light.turn_on:
                id: led_ring
                brightness: 75%
                effect: "Pause Blink"
            - lambda: id(va_running) = false;
            - lambda: id(mp_running) = false;
            - lambda: id(mww_running) = false;

      - if:
          condition:
            lambda: return id(voice_assistant_phase) == ${voice_assist_timer_finished_phase_id};
          then:
            - light.turn_on:
                id: led_ring
                brightness: 80%
                effect: "Announce Blink"
            - lambda: id(va_running) = true;
            - lambda: id(mp_running) = false;
            - lambda: id(mww_running) = false;

  - id: led_waiting_wake
    then:
      - light.turn_on:
          id: led_ring
          brightness: 55%
          effect: "VA Standby"

  - id: led_listening
    then:
      - lambda: |-
          id(fg_r)=${listen_fg_r}; id(fg_g)=${listen_fg_g}; id(fg_b)=${listen_fg_b};
          id(bg_r)=${listen_bg_r}; id(bg_g)=${listen_bg_g}; id(bg_b)=${listen_bg_b};
      - light.turn_on:
          id: led_ring
          brightness: 70%
          effect: "VA Rotate"

  - id: led_thinking
    then:
      - lambda: |-
          id(fg_r)=${think_fg_r}; id(fg_g)=${think_fg_g}; id(fg_b)=${think_fg_b};
          id(bg_r)=${think_bg_r}; id(bg_g)=${think_bg_g}; id(bg_b)=${think_bg_b};
      - light.turn_on:
          id: led_ring
          brightness: 70%
          effect: "VA Think Pulse"

  - id: va_timing_report
    mode: restart
    then:
      - lambda: |-
          auto ms_to_s = [](uint32_t ms) -> float { return ((float) ms) / 1000.0f; };
          const uint32_t t_listen = id(ts_va_listening_ms);
          const uint32_t t_vad    = id(ts_va_vad_end_ms);
          const uint32_t t_stt    = id(ts_va_stt_end_ms);
          const uint32_t t_tts    = id(ts_va_tts_start_ms);
          const uint32_t t_done   = id(ts_va_reply_done_ms);
          const uint32_t t_end    = id(ts_va_end_ms);

          if (t_stt == 0 || t_tts == 0 || t_done == 0 || t_done <= t_stt || t_tts < t_stt) {
            ESP_LOGI("va_timing", "VA Timing: incomplete (stt=%u tts=%u done=%u)", t_stt, t_tts, t_done);
            return;
          }

          const uint32_t total_ms = t_done - t_stt;
          const uint32_t think_ms = t_tts - t_stt;
          const uint32_t speak_ms = t_done - t_tts;

          auto pct = [&](uint32_t part_ms) -> float {
            return (total_ms > 0) ? (100.0f * ((float) part_ms) / (float) total_ms) : 0.0f;
          };

          ESP_LOGI("va_timing", "=== VA Timing Report (STT_END -> SPEECH_END) ===");
          ESP_LOGI("va_timing", "Total: %.2fs", ms_to_s(total_ms));
          ESP_LOGI("va_timing", "Thinking (STT_END->TTS_START): %.2fs (%.1f%%)", ms_to_s(think_ms), pct(think_ms));
          ESP_LOGI("va_timing", "Speaking (TTS_START->SPEECH_END): %.2fs (%.1f%%)", ms_to_s(speak_ms), pct(speak_ms));

          if (t_listen && t_vad && t_vad > t_listen) {
            ESP_LOGI("va_timing", "Pre: Listening->VAD_END: %.2fs", ms_to_s(t_vad - t_listen));
          }
          if (t_vad && t_stt && t_stt > t_vad) {
            ESP_LOGI("va_timing", "Pre: VAD_END->STT_END: %.2fs", ms_to_s(t_stt - t_vad));
          }
          if (t_end && t_end > t_done) {
            ESP_LOGI("va_timing", "Post: SPEECH_END->END(cleanup): %.2fs", ms_to_s(t_end - t_done));
          }
          ESP_LOGI("va_timing", "==============================================");

esphome:
  name: ${hostname}
  friendly_name: ${friendly}
  project:
    name: Waveshare HackMyHome.VoiceAssist
    version: "2.0.0"

  on_boot:
    priority: 600
    then:
      - logger.log:
          level: INFO
          format: "=== BOOT START"
      - logger.log:
          level: INFO
          format: "=== BOOT END"

  on_shutdown:
    then:
      - logger.log:
          level: INFO
          format: "SHUTDOWN"

esp32:
  board: esp32-s3-devkitc-1
  framework:
    type: esp-idf
    version: recommended
    sdkconfig_options:
      CONFIG_ESP32S3_DATA_CACHE_64KB: "y"
      CONFIG_ESP32S3_DATA_CACHE_LINE_64B: "y"
      CONFIG_ESP32S3_INSTRUCTION_CACHE_32KB: "y"
      CONFIG_SPIRAM_RODATA: "y"
      CONFIG_SPIRAM_FETCH_INSTRUCTIONS: "y"
      CONFIG_BT_ALLOCATION_FROM_SPIRAM_FIRST: "y"
      CONFIG_BT_BLE_DYNAMIC_ENV_MEMORY: "y"
      CONFIG_MBEDTLS_EXTERNAL_MEM_ALLOC: "y"
      CONFIG_MBEDTLS_SSL_PROTO_TLS1_3: "y"
      CONFIG_ESP32S3_DEFAULT_CPU_FREQ_240: "y"

logger:
  level: INFO

psram:
  mode: octal
  speed: 80MHz

wifi:
  ssid: ${ssid}
  password: ${password}
  fast_connect: true
  manual_ip:
    static_ip: ${ip}
    gateway: ${gateway}
    subnet: ${subnet}
    dns1: ${dns}
    dns2: 8.8.8.8

  ap:
    ssid: "${friendly} Fallback"
    password: ${password}

  on_connect:
    then:
      - logger.log:
          level: INFO
          format: "==== WiFi CONNECTED"
      - light.turn_on:
          id: led_ring
          brightness: 75%
          effect: "WiFi Blink"
      - if:
          condition:
            not:
              lambda: return id(voice_assistant_phase) == ${connected_wireless_api};
          then:
            - lambda: id(voice_assistant_phase) = ${connected_wireless};
      - script.execute: control_leds

  on_disconnect:
    then:
      - logger.log:
          level: INFO
          format: "==== WiFi DISCONNECTED"
      - script.execute: stop_wake_word
      - lambda: id(voice_assistant_phase) = ${no_connected};
      - script.execute: control_leds

api:
  encryption:
    key: ${api_key}

  on_client_connected:
    then:
      - logger.log:
          level: INFO
          format: "==== API CONNECTED"
      - light.turn_on:
          id: led_ring
          brightness: 75%
          effect: "API Blink"
      - lambda: id(voice_assistant_phase) = ${connected_wireless_api};
      - script.execute: control_leds
      - delay: 2s
      - script.execute: set_idle_or_mute_phase
      - script.execute: start_wake_word
      - script.execute: control_leds

  on_client_disconnected:
    then:
      - logger.log:
          level: INFO
          format: "==== API DISCONNECTED"
      - script.execute: stop_wake_word
