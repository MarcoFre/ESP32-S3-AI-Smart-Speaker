audio_adc:
  - platform: es7210
    id: adc_es7210
    i2c_id: bus_i2c
    address: 0x40
    sample_rate: 16000
    bits_per_sample: ${bits_per_sample}
    mic_gain: 24db

microphone:
  - platform: i2s_audio
    id: ${microphone_name}
    i2s_audio_id: bus_i2s
    adc_type: external
    i2s_din_pin: ${i2s_dout}
    sample_rate: 16000
    bits_per_sample: ${bits_per_sample}
    channel: right
    pdm: false

# DAC codec (ES8311)
audio_dac:
  - platform: es8311
    id: dac
    address: 0x18

speaker:
  - platform: i2s_audio
    id: ${speaker_name}
    i2s_audio_id: bus_i2s
    dac_type: external
    i2s_dout_pin: ${i2s_din}
    audio_dac: dac
    channel: mono
    sample_rate: ${sample_rate}
    bits_per_sample: ${bits_per_sample}
    buffer_duration: 100ms

  - platform: mixer
    id: spk_mixer
    output_speaker: spk_hw
    source_speakers:
      - id: ann_mixer_in
      - id: media_mixer_in

  - platform: resampler
    id: ann_spk
    output_speaker: ann_mixer_in
    sample_rate: ${sample_rate}

  - platform: resampler
    id: media_spk
    output_speaker: media_mixer_in
    sample_rate: ${sample_rate}

media_player:
  - platform: speaker
    id: ${mediaplayer_name}
    name: "Media Player"
    volume_increment: 1%
    task_stack_in_psram: true

    media_pipeline:
      speaker: media_spk
      format: FLAC
      sample_rate: ${sample_rate}
      num_channels: 1

    announcement_pipeline:
      speaker: ann_spk
      format: FLAC
      sample_rate: ${sample_rate}
      num_channels: 1
      
    files:
      - id: wake_word_triggered_sound
        file: ${wake_word_triggered_sound_file}
      - id: mute_switch_on_sound
        file: ${mute_switch_on_sound_file}
      - id: mute_switch_off_sound
        file: ${mute_switch_off_sound_file}
      - id: timer_finished_sound
        file: ${timer_finished_sound_file}
    on_announcement:
      then:
        - lambda: |-
            id(voice_assistant_phase_prev) =id(voice_assistant_phase);
        - logger.log:
            level: INFO
            format: "==== MEDIAPLAYER: ANNOUNCEMENT"
        - script.execute: stop_wake_word
        - light.turn_on:
            id: led_ring
            effect: "Announce Blink"
        - mixer_speaker.apply_ducking:
            id: media_mixer_in
            decibel_reduction: 10
            duration: 0s
        - wait_until:
            condition:
              not:
                - media_player.is_announcing: ${mediaplayer_name}
            timeout: 30s
        - mixer_speaker.apply_ducking:
            id: media_mixer_in
            decibel_reduction: 0
            duration: 1.2s
        - lambda: id(voice_assistant_phase) = id(voice_assistant_phase_prev);
        - script.execute: control_leds
        - if:
            condition:
              lambda: |-
                return id(voice_assistant_phase_prev) == ${voice_assist_idle_phase_id} ||
                       id(voice_assistant_phase_prev) == ${voice_assist_muted_phase_id};
            then:
              - script.execute: start_wake_word

    on_pause:
      then:
        - logger.log:
            level: INFO
            format: "==== MEDIAPLAYER: PAUSE"
        - light.turn_on:
            id: led_ring
            effect: "Pause Blink"
        - script.execute: set_idle_or_mute_phase
        - script.execute: start_wake_word
        - script.execute: control_leds

    on_play:
      then:
        - script.execute: stop_wake_word
        - if:
            condition:
              lambda: return id(voice_assistant_phase) == ${voice_assist_replying_phase_id};
            then:
              - logger.log:
                  level: INFO
                  format: "==== MEDIAPLAYER: WakeWord Speaking"
            else:
              - logger.log:
                  level: INFO
                  format: "==== MEDIAPLAYER: MUSIC PLAY"
              - lambda: id(voice_assistant_phase) = ${mediaplayer_play};
              - script.execute: control_leds

micro_wake_word:
  id: ${wakeword_name}
  stop_after_detection: True
  microphone:
    microphone: ${microphone_name}
    channels: 0
    gain_factor: ${mic_gain_factor}
  vad: 
