  # -------- Device Phases --------
  no_connected:                         "0"
  connected_wireless:                   "1"
  connected_wireless_api:               "2"

  # -------- Voice Assistant Phases --------
  voice_assist_idle_phase_id:           "11"
  voice_assist_listening_phase_id:      "12"
  voice_assist_thinking_phase_id:       "13"
  voice_assist_replying_phase_id:       "14"
  voice_assist_not_ready_phase_id:      "15"
  voice_assist_error_phase_id:          "16"
  voice_assist_muted_phase_id:          "17"
  voice_assist_timer_finished_phase_id: "18"

  # -------- MediaPlayer Phases --------
